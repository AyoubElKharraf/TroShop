NODE_ENV=development
PORT=3001
TRUST_PROXY=0

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
# Utilisateur MySQL (éviter root en prod ; créer un utilisateur dédié avec droits sur la base uniquement)
MYSQL_USER=root
# Mot de passe MySQL (obligatoire si votre utilisateur en a un — ne pas laisser vide si MySQL refuse la connexion)
MYSQL_PASSWORD=
MYSQL_DATABASE=trocspot

# Obligatoire en production (min. 32 caractères)
JWT_SECRET=changez-moi-en-production-une-longue-chaine-aleatoire-min-32

# Origines autorisées (CORS), séparées par des virgules si plusieurs
CLIENT_ORIGIN=http://localhost:8080

# Optionnel : email du compte qui peut publier le catalogue (rôle admin appliqué à la connexion)
# ADMIN_EMAIL=admin@votredomaine.fr

# Optionnel : envoi des emails (mot de passe oublié). Sans cela, en dev le lien s’affiche dans les logs serveur.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@votredomaine.fr
